{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite + React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "0.0.0.0"],
      "port": 5173
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8001
    },
    {
      "name": "Flower (Celery Monitor)",
      "runtimeExecutable": "celery",
      "runtimeArgs": ["-A", "app.tasks.celery_app", "flower", "--port=5555"],
      "port": 5555
    }
  ]
}
