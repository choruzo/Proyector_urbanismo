# ─────────────────────────────────────────────────────────────
# Copia este fichero a .env y ajusta los valores para tu entorno
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Aplicación
DEBUG=true
APP_NAME="Proyector Urbanístico Getafe"

# Base de datos PostgreSQL + PostGIS
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=getafe_urbanismo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esto_en_produccion

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Ciudad objetivo (no cambiar para Getafe)
MUNICIPIO_NOMBRE=Getafe
MUNICIPIO_CODIGO_INE=28065
MUNICIPIO_CODIGO_CATASTRO=28065
PROVINCIA_CODIGO=28

# Rango de datos históricos
YEAR_START=2001
YEAR_END=2026

# CORS — orígenes permitidos (separados por coma si hay varios)
# En producción, sustituir localhost por el dominio real
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
